# Zugangs-Token für Bildung in Bildern
# Diesen Wert in der Cloudflare Pages Build-Konfiguration setzen.
# Nutzer greifen zu via: https://app.example.com/?token=<WERT>
NEXT_PUBLIC_ACCESS_TOKEN=

# Dashboard-Token für Eltern/Betreuer (Issue #28)
# Separater Code für das Lernweg-Dashboard unter /dashboard
# Zugang via: https://app.example.com/dashboard?dt=<WERT>
# Auch als Cloudflare Workers-Env-Variable DASHBOARD_TOKEN setzen (für die API).
NEXT_PUBLIC_DASHBOARD_TOKEN=
DASHBOARD_TOKEN=
